generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  sales_manager
  product_manager
}

enum OrderStatus {
  processing
  in_transit
  delivered
  cancelled
  refund_requested
  refund_approved
  refund_rejected
}

enum DeliveryStatus {
  processing
  in_transit
  delivered
}

enum ReviewStatus {
  pending
  approved
  rejected
}

enum DiscountScope {
  product
  category
}

enum DiscountType {
  percentage
  fixed
}

// Req 13: customer - ID, name, tax ID, email, home address, password
model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(customer)
  taxId        String?  @map("tax_id")
  homeAddress  String?  @map("home_address")
  createdAt    DateTime @default(now()) @map("created_at")

  wishlist Wishlist?
  cart     Cart?
  orders   Order[]
  reviews  Review[]

  @@map("users")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  products  Product[]
  discounts Discount[]

  @@map("categories")
}

// Req 9: product - ID, name, model, serial number, description,
// quantity in stocks, price, warranty status, distributor information
model Product {
  id              Int      @id @default(autoincrement())
  name            String
  model           String   @default("")
  serialNumber    String   @default("") @map("serial_number")
  description     String   @default("")
  price           Decimal  @db.Decimal(10, 2)
  cost            Decimal  @db.Decimal(10, 2)
  stock           Int      @default(0)
  warrantyStatus  String   @default("") @map("warranty_status")
  distributorInfo String   @default("") @map("distributor_info")
  categoryId      Int      @map("category_id")
  createdAt       DateTime @default(now()) @map("created_at")

  category      Category       @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  specs         ProductSpec[]
  wishlistItems WishlistItem[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  reviews       Review[]
  discounts     Discount[]

  @@index([categoryId])
  @@index([name])
  @@map("products")
}

model ProductImage {
  id        Int    @id @default(autoincrement())
  productId Int    @map("product_id")
  url       String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductSpec {
  id        Int    @id @default(autoincrement())
  productId Int    @map("product_id")
  key       String
  value     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_specs")
}

model Wishlist {
  id     Int @id @default(autoincrement())
  userId Int @unique @map("user_id")

  user  User           @relation(fields: [userId], references: [id])
  items WishlistItem[]

  @@map("wishlists")
}

model WishlistItem {
  id         Int @id @default(autoincrement())
  wishlistId Int @map("wishlist_id")
  productId  Int @map("product_id")

  wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@unique([wishlistId, productId])
  @@map("wishlist_items")
}

model Cart {
  id     Int @id @default(autoincrement())
  userId Int @unique @map("user_id")

  user  User       @relation(fields: [userId], references: [id])
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id                Int     @id @default(autoincrement())
  cartId            Int     @map("cart_id")
  productId         Int     @map("product_id")
  quantity          Int     @default(1)
  unitPriceSnapshot Decimal @map("unit_price_snapshot") @db.Decimal(10, 2)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int         @map("user_id")
  totalAmount     Decimal     @map("total_amount") @db.Decimal(10, 2)
  status          OrderStatus @default(processing)
  deliveryAddress String      @default("") @map("delivery_address")
  createdAt       DateTime    @default(now()) @map("created_at")

  user     User        @relation(fields: [userId], references: [id])
  items    OrderItem[]
  delivery Delivery?
  invoice  Invoice?

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id                Int     @id @default(autoincrement())
  orderId           Int     @map("order_id")
  productId         Int     @map("product_id")
  quantity          Int
  unitPriceSnapshot Decimal @map("unit_price_snapshot") @db.Decimal(10, 2)
  costSnapshot      Decimal @map("cost_snapshot") @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// Req 12: delivery list - delivery ID, customer ID, product ID, quantity,
// total price, delivery address, completed field
model Delivery {
  id              Int            @id @default(autoincrement())
  orderId         Int            @unique @map("order_id")
  deliveryStatus  DeliveryStatus @default(processing) @map("delivery_status")
  deliveryAddress String         @default("") @map("delivery_address")
  completed       Boolean        @default(false)
  updatedAt       DateTime       @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("deliveries")
}

model Invoice {
  id        Int      @id @default(autoincrement())
  orderId   Int      @unique @map("order_id")
  invoiceNo String   @unique @map("invoice_no")
  pdfPath   String?  @map("pdf_path")
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("invoices")
}

model Review {
  id        Int          @id @default(autoincrement())
  userId    Int          @map("user_id")
  productId Int          @map("product_id")
  rating    Int
  comment   String       @default("")
  status    ReviewStatus @default(pending)
  createdAt DateTime     @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("reviews")
}

model Discount {
  id         Int           @id @default(autoincrement())
  scope      DiscountScope
  productId  Int?          @map("product_id")
  categoryId Int?          @map("category_id")
  type       DiscountType
  value      Decimal       @db.Decimal(10, 2)
  startAt    DateTime      @map("start_at")
  endAt      DateTime      @map("end_at")
  createdAt  DateTime      @default(now()) @map("created_at")

  product  Product?  @relation(fields: [productId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  @@map("discounts")
}
