# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example for local Postgres:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/clothingstore?schema=public"

# JWT secret — use any long random string
JWT_SECRET="change-this-to-a-random-secret-string-at-least-32-chars"

# Server port
PORT=4000
